      <weekDay>1</weekDay>
      <DayOfMonth>1</DayOfMonth>
      <parallel>N</parallel>
      <draw>Y</draw>
      <nr>0</nr>
      <xloc>50</xloc>
      <yloc>200</yloc>
    </entry>

    <entry>
      <name>Set Variables</name>
      <description>Set CSV_FILE_PATH variable</description>
      <type>SET_VARIABLES</type>
      <replacevars>Y</replacevars>
      <filename/>
      <file_variable_type>JVM</file_variable_type>
      <fields>
        <field>
          <variable_name>CSV_FILE_PATH</variable_name>
          <variable_value>/home/god/Downloads/datain/samplestore-general.csv</variable_value>
          <variable_type>JVM</variable_type>
        </field>
      </fields>
      <parallel>N</parallel>
      <draw>Y</draw>
      <nr>0</nr>
      <xloc>200</xloc>
      <yloc>200</yloc>
    </entry>

    <entry>
      <name>Check File Exists</name>
      <description>Check if CSV file exists</description>
      <type>FILE_EXISTS</type>
      <filename>${CSV_FILE_PATH}</filename>
      <parallel>N</parallel>
      <draw>Y</draw>
      <nr>0</nr>
      <xloc>370</xloc>
      <yloc>200</yloc>
    </entry>

    <entry>
      <name>HTTP Download</name>
      <description>Download CSV from GitHub</description>
      <type>HTTP</type>
      <url>https://raw.githubusercontent.com/BosenkoTM/workshop-on-ETL/main/data_for_lessons/samplestore-general.csv</url>
      <targetfilename>${CSV_FILE_PATH}</targetfilename>
      <file_appended>N</file_appended>
      <date_time_added>N</date_time_added>
      <target_file_extension/>
      <uploadfilename/>
      <url_fieldname/>
      <run_every_row>N</run_every_row>
      <username/>
      <password/>
      <proxy_host/>
      <proxy_port/>
      <nonproxy_hosts/>
      <addfilenameresult>N</addfilenameresult>
      <headers/>
      <parallel>N</parallel>
      <draw>Y</draw>
      <nr>0</nr>
      <xloc>370</xloc>
      <yloc>350</yloc>
    </entry>

    <entry>
      <name>Truncate Tables</name>
      <description>Truncate orders, customers, products before load</description>
      <type>SQL</type>
      <connection>MySQL_Target</connection>
      <sql>DELETE FROM orders; DELETE FROM customers; DELETE FROM products; DELETE FROM analytics_profit;</sql>
      <useVariableSubstitution>N</useVariableSubstitution>
      <sqlfromfile>N</sqlfromfile>
      <sqlfilename/>
      <sendOneStatement>N</sendOneStatement>
      <parallel>N</parallel>
      <draw>Y</draw>
      <nr>0</nr>
      <xloc>550</xloc>
      <yloc>350</yloc>
    </entry>

    <entry>
