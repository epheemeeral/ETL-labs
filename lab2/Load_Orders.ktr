  <step>
    <name>Value Mapper</name>
    <type>ValueMapper</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribute/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <field_to_use>returned</field_to_use>
    <target_field>returned_flag</target_field>
    <non_match_default>0</non_match_default>
    <fields>
      <field><source_value>Yes</source_value><target_value>1</target_value></field>
      <field><source_value>No</source_value><target_value>0</target_value></field>
      <field><source_value/><target_value>0</target_value></field>
    </fields>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>460</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Memory Group by</name>
    <type>MemoryGroupBy</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribute/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <give_back_row>N</give_back_row>
    <group>
      <field><name>row_id</name></field>
    </group>
    <fields>
      <field><aggregate>order_date</aggregate><subject>order_date</subject><type>FIRST</type><valuefield/></field>
      <field><aggregate>ship_date</aggregate><subject>ship_date</subject><type>FIRST</type><valuefield/></field>
      <field><aggregate>ship_mode</aggregate><subject>ship_mode</subject><type>FIRST</type><valuefield/></field>
      <field><aggregate>sales</aggregate><subject>sales</subject><type>FIRST</type><valuefield/></field>
      <field><aggregate>quantity</aggregate><subject>quantity</subject><type>FIRST</type><valuefield/></field>
      <field><aggregate>discount</aggregate><subject>discount</subject><type>FIRST</type><valuefield/></field>
      <field><aggregate>profit</aggregate><subject>profit</subject><type>FIRST</type><valuefield/></field>
      <field><aggregate>returned_flag</aggregate><subject>returned_flag</subject><type>FIRST</type><valuefield/></field>
      <field><aggregate>person</aggregate><subject>person</subject><type>FIRST</type><valuefield/></field>
    </fields>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>640</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Filter rows</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribute/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <send_true_to>Table output</send_true_to>
    <send_false_to>Write to log</send_false_to>
    <compare>
      <condition>
        <negated>N</negated>
        <leftvalue/>
        <function>-</function>
        <rightvalue/>
        <conditions>
          <condition>
            <negated>N</negated>
            <leftvalue>order_date</leftvalue>
            <function>IS NOT NULL</function>
            <rightvalue/>
          </condition>
          <condition>
            <negated>N</negated>
            <operator>AND</operator>
            <leftvalue>ship_date</leftvalue>
            <function>IS NOT NULL</function>
            <rightvalue/>
          </condition>
          <condition>
            <negated>N</negated>
            <operator>AND</operator>
            <leftvalue>person</leftvalue>
            <function>=</function>
            <rightvalue/>
            <value><name>constant</name><type>String</type><text>Kelly Williams</text><length>-1</length><precision>-1</precision><isnull>N</isnull><mask/></value>
          </condition>
        </conditions>
      </condition>
    </compare>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>820</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Table output</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribute/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>MySQL_Target</connection>
    <schema/>
    <table>orders</table>
    <commit>1000</commit>
    <truncate>N</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <fields>
      <field><column_name>row_id</column_name><stream_name>row_id</stream_name></field>
      <field><column_name>order_date</column_name><stream_name>order_date</stream_name></field>
      <field><column_name>ship_date</column_name><stream_name>ship_date</stream_name></field>
      <field><column_name>ship_mode</column_name><stream_name>ship_mode</stream_name></field>
      <field><column_name>sales</column_name><stream_name>sales</stream_name></field>
      <field><column_name>quantity</column_name><stream_name>quantity</stream_name></field>
      <field><column_name>discount</column_name><stream_name>discount</stream_name></field>
      <field><column_name>profit</column_name><stream_name>profit</stream_name></field>
      <field><column_name>returned</column_name><stream_name>returned_flag</stream_name></field>
      <field><column_name>person</column_name><stream_name>person</stream_name></field>
    </fields>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>1020</xloc><yloc>150</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Write to log</name>
    <type>WriteToLog</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribute/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <loglevel>log_level_basic</loglevel>
    <displayHeader>Y</displayHeader>
    <limitRows>N</limitRows>
    <limitRowsNumber>0</limitRowsNumber>
    <logmessage>REJECTED ROW (NULL date or wrong Person)</logmessage>
    <fields>
      <field><name>row_id</name></field>
      <field><name>order_date</name></field>
      <field><name>ship_date</name></field>
      <field><name>person</name></field>
    </fields>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>1020</xloc><yloc>320</yloc><draw>Y</draw></GUI>
  </step>

</transformation>
