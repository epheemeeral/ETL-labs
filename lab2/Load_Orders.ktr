      <field><name>Person</name><rename>person</rename><length>-2</length><precision>-2</precision></field>
    </fields>
    <select_unspecified>N</select_unspecified>
    <meta>
      <name>row_id</name><rename/><type>Integer</type><length>-2</length><precision>0</precision><conversion_mask>#</conversion_mask><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>N</lenient_string_to_number><encoding/><decimal_symbol>.</decimal_symbol><grouping_symbol>,</grouping_symbol><currency_symbol/><storage_type/>
    </meta>
    <meta>
      <name>order_date</name><rename/><type>Date</type><length>-2</length><precision>-2</precision><conversion_mask/><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>N</lenient_string_to_number><encoding/><decimal_symbol/><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
    <meta>
      <name>ship_date</name><rename/><type>Date</type><length>-2</length><precision>-2</precision><conversion_mask/><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>N</lenient_string_to_number><encoding/><decimal_symbol/><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
    <meta>
      <name>ship_mode</name><rename/><type>String</type><length>50</length><precision>-2</precision><conversion_mask/><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>N</lenient_string_to_number><encoding/><decimal_symbol/><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
    <meta>
      <name>sales</name><rename/><type>Number</type><length>10</length><precision>2</precision><conversion_mask>#.##</conversion_mask><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>Y</lenient_string_to_number><encoding/><decimal_symbol>.</decimal_symbol><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
    <meta>
      <name>quantity</name><rename/><type>Integer</type><length>-2</length><precision>0</precision><conversion_mask>#.#</conversion_mask><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>Y</lenient_string_to_number><encoding/><decimal_symbol>.</decimal_symbol><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
    <meta>
      <name>discount</name><rename/><type>Number</type><length>4</length><precision>2</precision><conversion_mask>#.##</conversion_mask><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>Y</lenient_string_to_number><encoding/><decimal_symbol>.</decimal_symbol><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
    <meta>
      <name>profit</name><rename/><type>Number</type><length>10</length><precision>2</precision><conversion_mask>#.##</conversion_mask><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>Y</lenient_string_to_number><encoding/><decimal_symbol>.</decimal_symbol><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
    <meta>
      <name>returned</name><rename/><type>String</type><length>10</length><precision>-2</precision><conversion_mask/><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>N</lenient_string_to_number><encoding/><decimal_symbol/><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
    <meta>
      <name>person</name><rename/><type>String</type><length>100</length><precision>-2</precision><conversion_mask/><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>N</lenient_string_to_number><encoding/><decimal_symbol/><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
