<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>Analytics_Profit</name>
    <description>Variant 17 - Task 2: Profit Analysis (by Category and Region)</description>
    <extended_description/>
    <trans_version/>
    <trans_type>Normal</trans_type>
    <trans_status>0</trans_status>
    <directory>/</directory>
    <parameters/>
    <log>
      <trans-log-table><connection/><schema/><table/><size_limit_lines/><interval/><timeout_days/><field/></trans-log-table>
      <perf-log-table><connection/><schema/><table/><interval/><timeout_days/><field/></perf-log-table>
      <channel-log-table><connection/><schema/><table/><timeout_days/><field/></channel-log-table>
      <step-log-table><connection/><schema/><table/><timeout_days/><field/></step-log-table>
      <metrics-log-table><connection/><schema/><table/><timeout_days/><field/></metrics-log-table>
    </log>
    <maxdate><connection/><table/><field/><offset>0.0</offset><maxdiff>0.0</maxdiff></maxdate>
    <size_rowset>10000</size_rowset>
    <sleep_time_empty>50</sleep_time_empty>
    <sleep_time_full>50</sleep_time_full>
    <unique_connections>N</unique_connections>
    <feedback_shown>Y</feedback_shown>
    <feedback_size>50000</feedback_size>
    <using_thread_priorities>Y</using_thread_priorities>
    <shared_objects_file/>
    <capture_step_performance>N</capture_step_performance>
    <step_performance_capturing_delay>1000</step_performance_capturing_delay>
    <step_performance_capturing_size_limit>100</step_performance_capturing_size_limit>
    <dependencies/>
    <partitionschemas/>
    <slaveservers/>
    <clusterschemas/>
    <created_user>-</created_user>
    <created_date>2026/04/04 23:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/04/04 23:00:00.000</modified_date>
    <key_for_session_key>H4sIAAAAAAAAAAMAAAAAAAAAAAA=</key_for_session_key>
    <is_key_private>N</is_key_private>
  </info>
  <notepads/>
  <order>
    <hop><from>CSV file input</from><to>Select values</to><enabled>Y</enabled></hop>
    <hop><from>Select values</from><to>Memory Group by</to><enabled>Y</enabled></hop>
    <hop><from>Memory Group by</from><to>Write to log</to><enabled>Y</enabled></hop>
  </order>

  <step>
    <name>CSV file input</name>
    <type>CsvInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribute/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>${CSV_FILE_PATH}</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>;</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>N</newline_possible>
    <encoding>UTF-8</encoding>
    <fields>
      <field><name>Row ID</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Order ID</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Order Date</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Ship Date</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Ship Mode</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Customer ID</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Customer Name</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Segment</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Country</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>City</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>State</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Postal Code</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Region</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Product ID</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Category</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Sub-Category</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Product Name</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Sales</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Quantity</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Discount</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Profit</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Returned</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
      <field><name>Person</name><type>String</type><format/><currency/><decimal/><group/><length/><precision/><trim_type>none</trim_type></field>
    </fields>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>100</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Select values</name>
    <type>SelectValues</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribute/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <fields>
      <field><name>Category</name><rename>category</rename><length>-2</length><precision>-2</precision></field>
      <field><name>Region</name><rename>region</rename><length>-2</length><precision>-2</precision></field>
      <field><name>Sales</name><rename>sales</rename><length>-2</length><precision>-2</precision></field>
      <field><name>Profit</name><rename>profit</rename><length>-2</length><precision>-2</precision></field>
      <field><name>Discount</name><rename>discount</rename><length>-2</length><precision>-2</precision></field>
    </fields>
    <select_unspecified>N</select_unspecified>
    <meta>
      <name>category</name><rename/><type>String</type><length>50</length><precision>-2</precision><conversion_mask/><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>N</lenient_string_to_number><encoding/><decimal_symbol/><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
    <meta>
      <name>region</name><rename/><type>String</type><length>50</length><precision>-2</precision><conversion_mask/><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>N</lenient_string_to_number><encoding/><decimal_symbol/><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
    <meta>
      <name>sales</name><rename/><type>Number</type><length>10</length><precision>2</precision><conversion_mask>#.##</conversion_mask><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>Y</lenient_string_to_number><encoding/><decimal_symbol>.</decimal_symbol><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
    <meta>
      <name>profit</name><rename/><type>Number</type><length>10</length><precision>2</precision><conversion_mask>#.##</conversion_mask><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>Y</lenient_string_to_number><encoding/><decimal_symbol>.</decimal_symbol><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
    <meta>
      <name>discount</name><rename/><type>Number</type><length>4</length><precision>2</precision><conversion_mask>#.##</conversion_mask><date_format_lenient>false</date_format_lenient><date_format_locale/><date_format_timezone/><lenient_string_to_number>Y</lenient_string_to_number><encoding/><decimal_symbol>.</decimal_symbol><grouping_symbol/><currency_symbol/><storage_type/>
    </meta>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>300</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Memory Group by</name>
    <type>MemoryGroupBy</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribute/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <give_back_row>N</give_back_row>
    <group>
      <field><name>category</name></field>
      <field><name>region</name></field>
    </group>
    <fields>
      <field><aggregate>order_count</aggregate><subject>category</subject><type>COUNT_ANY</type><valuefield/></field>
      <field><aggregate>total_sales</aggregate><subject>sales</subject><type>SUM</type><valuefield/></field>
      <field><aggregate>total_profit</aggregate><subject>profit</subject><type>SUM</type><valuefield/></field>
      <field><aggregate>avg_profit</aggregate><subject>profit</subject><type>AVERAGE</type><valuefield/></field>
      <field><aggregate>avg_discount</aggregate><subject>discount</subject><type>AVERAGE</type><valuefield/></field>
      <field><aggregate>min_profit</aggregate><subject>profit</subject><type>MIN</type><valuefield/></field>
      <field><aggregate>max_profit</aggregate><subject>profit</subject><type>MAX</type><valuefield/></field>
    </fields>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>500</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Write to log</name>
    <type>WriteToLog</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribute/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <loglevel>log_level_basic</loglevel>
    <displayHeader>Y</displayHeader>
    <limitRows>N</limitRows>
    <limitRowsNumber>0</limitRowsNumber>
    <logmessage>===== PROFIT ANALYSIS BY CATEGORY AND REGION =====</logmessage>
    <fields>
      <field><name>category</name></field>
      <field><name>region</name></field>
      <field><name>order_count</name></field>
      <field><name>total_sales</name></field>
      <field><name>total_profit</name></field>
      <field><name>avg_profit</name></field>
      <field><name>avg_discount</name></field>
      <field><name>min_profit</name></field>
      <field><name>max_profit</name></field>
    </fields>
    <cluster_schema/>
    <remotesteps><input/><output/></remotesteps>
    <GUI><xloc>700</xloc><yloc>200</yloc><draw>Y</draw></GUI>
  </step>

</transformation>
